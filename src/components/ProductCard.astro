---
import type { Product } from '../types/schemas';
import { productDefaults } from '../config/defaults';

interface Props {
  product: Product;
}

const { product } = Astro.props;

const price = product.priceOverride || productDefaults.price;
---

<div
  class="product-card flex flex-col bg-white rounded-xl overflow-hidden border border-gray-100 shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all duration-200"
  data-slug={product.slug}
  data-title={product.title}
  data-price={price}
  data-sku={product.sku}
>
  <!-- Image area — fixed height, object-contain so nothing is cropped -->
  <a href={`/product/${product.slug}`} class="block h-48 bg-gray-50 flex items-center justify-center p-3 border-b border-gray-100">
    <img
      src={`/images/products/${product.image}`}
      alt={product.title}
      class="max-h-full max-w-full object-contain"
      loading="lazy"
      decoding="async"
    />
  </a>

  <!-- Card body -->
  <div class="p-4 flex flex-col flex-grow gap-2">
    <!-- Title -->
    <h3 class="text-sm font-semibold leading-snug text-gray-800 line-clamp-2 min-h-[2.6rem]">
      <a href={`/product/${product.slug}`} class="hover:text-[#0D47A1] transition-colors">
        {product.title}
      </a>
    </h3>

    <!-- Price -->
    <div class="text-xl font-extrabold text-[#E53935] mt-auto">{price} грн</div>

    <!-- Add to cart button -->
    <button
      class="add-to-cart-btn w-full py-2.5 text-sm font-bold text-white bg-[#0D47A1] rounded-lg hover:bg-[#1565C0] transition-colors cursor-pointer mt-1"
      data-sku={product.sku}
      data-title={product.title}
      data-price={price}
    >
      Додати у кошик
    </button>
  </div>
</div>

<script>
  document.querySelectorAll('.add-to-cart-btn').forEach(btn => {
    btn.addEventListener('click', (e) => {
      e.preventDefault();
      e.stopPropagation();

      const sku = btn.getAttribute('data-sku');
      const title = btn.getAttribute('data-title');
      const price = Number(btn.getAttribute('data-price'));

      if (!sku || !title) return;

      try {
        let cart = JSON.parse(localStorage.getItem('shoppingCart') || '[]');
        const existing = cart.find((item: any) => item.sku === sku && !item.isCustom);

        if (existing) {
          existing.count++;
        } else {
          cart.push({ sku, title, price, count: 1, isCustom: false, customRequirements: null });
        }

        localStorage.setItem('shoppingCart', JSON.stringify(cart));
        window.dispatchEvent(new Event('cart-updated'));

        // Toast
        const toast = document.getElementById('cart-toast');
        if (toast) {
          toast.classList.remove('translate-y-20', 'opacity-0', 'pointer-events-none');
          toast.classList.add('translate-y-0', 'opacity-100');
          setTimeout(() => {
            toast.classList.remove('translate-y-0', 'opacity-100');
            toast.classList.add('translate-y-20', 'opacity-0', 'pointer-events-none');
          }, 2500);
        }

        // Button feedback
        const origText = btn.textContent;
        (btn as HTMLButtonElement).textContent = '✓ Додано';
        (btn as HTMLButtonElement).style.backgroundColor = '#10b981';
        setTimeout(() => {
          (btn as HTMLButtonElement).textContent = origText || 'Додати у кошик';
          (btn as HTMLButtonElement).style.backgroundColor = '';
        }, 1500);

      } catch (err) {
        console.error(err);
      }
    });
  });
</script>
