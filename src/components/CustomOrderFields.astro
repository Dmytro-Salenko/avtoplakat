---
interface Props {
  sku: string;
  isCustom?: boolean;
  requirements?: string | null;
}

const { sku, isCustom = false, requirements = "" } = Astro.props;
---
<div class="custom-fields-wrapper mt-3 pt-3 border-t border-dashed border-border" data-sku={sku}>
  <label class="custom-toggle-label inline-flex items-center gap-2 text-xs font-semibold text-text-muted cursor-pointer">
    <input type="checkbox" class="custom-toggle-checkbox w-4 h-4 rounded border-border text-primary focus:ring-primary" checked={isCustom} />
    <span>Потрібен нестандартний розмір або матеріал</span>
  </label>
  
  <div class="custom-input-container mt-2" style={isCustom ? "display: block;" : "display: none;"}>
    <label class="block text-xs font-medium text-text-muted mb-1">
      <span>Опишіть потрібний розмір, матеріал та інші вимоги:</span>
      <textarea class="custom-textarea w-full border border-border rounded p-2 text-xs text-text-dark mt-1 focus:ring-1 focus:ring-primary focus:border-primary focus:outline-none" rows="2" placeholder="Наприклад: розмір 1000х1600 мм, товщина пластику 4 мм, матове покриття">{requirements || ""}</textarea>
    </label>
  </div>
</div>
