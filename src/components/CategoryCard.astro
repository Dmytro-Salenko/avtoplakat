---
interface Props {
  slug: string;
  name: string;
  count: number;
}

const { slug, name, count } = Astro.props;

const iconMap: Record<string, string> = {
  'tractor-structure': '🚜',
  'truck-structure': '🚛',
  'car-structure': '🚗',
  'road-safety-rules': '🛑',
  'first-aid': '🚑'
};

const icon = iconMap[slug] || '📋';
---
<a href={`/category/${slug}`} class="flex items-center gap-5 p-6 bg-white border border-border rounded-xl shadow-sm hover:-translate-y-0.5 hover:shadow-md hover:border-primary transition-all duration-200">
  <div class="text-4xl flex items-center justify-center w-16 h-16 bg-bg-light rounded-lg">
    {icon}
  </div>
  <div class="flex-1">
    <h3 class="text-base font-bold text-text-dark mb-1 leading-snug">{name}</h3>
    <span class="text-xs text-text-muted">{count} товарів</span>
  </div>
</a>
