---
import { siteConfig } from '../config/defaults';
---
<header class="sticky top-0 z-50 bg-white border-b border-border shadow-sm">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
    
    <!-- Logo -->
    <a href="/" class="text-xl font-extrabold tracking-tight text-text-dark flex items-center gap-1">
      <span class="text-primary">AVTO</span>PLAKAT
      <span class="text-lg">🇺🇦</span>
    </a>
    
    <!-- Main Navigation Links -->
    <nav class="hidden md:flex items-center gap-8">
      <a href="/" class="font-medium text-text-muted hover:text-primary transition-colors">Каталог</a>
      <a href="/about" class="font-medium text-text-muted hover:text-primary transition-colors">Про нас</a>
      <a href="/shipping-payment" class="font-medium text-text-muted hover:text-primary transition-colors">Доставка та оплата</a>
      <a href="/contacts" class="font-medium text-text-muted hover:text-primary transition-colors">Контакти</a>
    </nav>
    
    <!-- Right Actions: Phone + Cart -->
    <div class="flex items-center gap-4 sm:gap-6">
      
      <!-- Highly Visible Phone Number -->
      {siteConfig.phone ? (
        <a href={`tel:${siteConfig.phone}`} class="text-sm sm:text-base font-bold text-primary hover:underline flex items-center gap-1" aria-label="Зателефонувати">
          <span class="hidden sm:inline">📞</span>
          {siteConfig.phone}
        </a>
      ) : (
        <span class="text-xs text-text-muted italic hidden sm:inline" title="Коментар розробника: TODO Введіть номер телефону в defaults.ts">
          [Контакти]
        </span>
      )}
      
      <!-- Cart Link -->
      <a href="/cart" class="flex items-center gap-2 border border-border px-3.5 py-2 rounded-lg bg-bg-light hover:bg-white text-text-dark font-bold hover:text-primary transition-all text-sm" id="header-cart-btn" aria-label="Кошик">
        <span>🛒</span>
        <span>Кошик</span>
        <span id="header-cart-count" class="bg-primary text-white text-xs px-2 py-0.5 rounded-full font-extrabold ml-1">
          0
        </span>
      </a>
    </div>
  </div>
</header>

<script>
  function updateHeaderCart() {
    try {
      const cart = JSON.parse(localStorage.getItem('shoppingCart') || '[]');
      const totalCount = cart.reduce((sum: number, item: any) => sum + item.count, 0);
      const badge = document.getElementById('header-cart-count');
      if (badge) {
        badge.textContent = totalCount.toString();
      }
    } catch (e) {
      console.error(e);
    }
  }
  
  updateHeaderCart();
  window.addEventListener('storage', updateHeaderCart);
  window.addEventListener('cart-updated', updateHeaderCart);
</script>
