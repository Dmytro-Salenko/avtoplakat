---
import { siteConfig } from '../config/defaults';
---
<footer class="bg-gray-900 text-gray-300 pt-12 mt-auto">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-12 grid grid-cols-1 md:grid-cols-4 gap-8">
    
    <!-- Logo & Info -->
    <div class="md:col-span-2">
      <h3 class="text-white text-xl font-extrabold mb-4">AVTOPLAKAT <span class="text-lg">🇺🇦</span></h3>
      <p class="text-gray-400 text-sm mb-6 max-w-sm">Український каталог навчальних автоплакатів для автошкіл, технікумів та інших навчальних закладів.</p>
      <div class="inline-block bg-yellow-400/10 border border-secondary text-secondary px-4 py-2 rounded text-xs font-semibold">
        Доставка по Україні — лише Новою поштою
      </div>
    </div>
    
    <!-- Navigation Links -->
    <div>
      <h4 class="text-white font-semibold text-sm tracking-wider uppercase mb-4">Навігація</h4>
      <ul class="space-y-2 text-sm">
        <li><a href="/" class="text-gray-400 hover:text-white transition-colors">Каталог</a></li>
        <li><a href="/about" class="text-gray-400 hover:text-white transition-colors">Про нас</a></li>
        <li><a href="/shipping-payment" class="text-gray-400 hover:text-white transition-colors">Доставка та оплата</a></li>
        <li><a href="/contacts" class="text-gray-400 hover:text-white transition-colors">Контакти</a></li>
      </ul>
    </div>
    
    <!-- Contact Info -->
    <div>
      <h4 class="text-white font-semibold text-sm tracking-wider uppercase mb-4">Контакти</h4>
      <ul class="space-y-2 text-sm text-gray-400">
        <li>Email: {siteConfig.email}</li>
        {siteConfig.phone && (
          <li>Телефон: <a href={`tel:${siteConfig.phone}`} class="hover:text-white">{siteConfig.phone}</a></li>
        )}
      </ul>
    </div>
  </div>
  
  <!-- Footer Bottom -->
  <div class="border-t border-gray-800 py-6 text-center text-xs text-gray-500">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <p>&copy; {new Date().getFullYear()} AVTOPLAKAT UA. Всі права захищені.</p>
    </div>
  </div>
</footer>
