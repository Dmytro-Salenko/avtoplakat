---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import ProductSpecs from '../../components/ProductSpecs.astro';
import ProductCard from '../../components/ProductCard.astro';
import CartDrawer from '../../components/CartDrawer.astro';
import { productDefaults } from '../../config/defaults';

export async function getStaticPaths() {
  const allProducts = await getCollection('products');
  const publishedProducts = allProducts.filter(p => p.data.status === 'published');
  
  return publishedProducts.map(product => ({
    params: { slug: product.data.slug },
    props: { product }
  }));
}

const { product } = Astro.props;

const categoryNames: Record<string, string> = {
  'tractor-structure': 'Будова трактора',
  'truck-structure': 'Будова вантажного автомобіля',
  'car-structure': 'Будова легкового автомобіля',
  'road-safety-rules': 'Безпека дорожнього руху',
  'first-aid': 'Домедична допомога'
};

const categoryName = categoryNames[product.data.category] || 'Каталог';

const price = product.data.priceOverride || productDefaults.price;

// Find similar products in the same category
const allProducts = await getCollection('products');
const publishedProducts = allProducts.filter(p => p.data.status === 'published');
const similarProducts = publishedProducts
  .filter(p => p.data.category === product.data.category && p.data.slug !== product.data.slug)
  .slice(0, 4);

// Schema.org Product + Offer (JSON-LD)
const siteOrigin = Astro.site ? Astro.site.origin : Astro.url.origin;
const productUrl = Astro.url.href;
const productImageUrl = `${siteOrigin}/images/products/${product.data.image}`;
const productSchema = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": product.data.title,
  "description": `Навчальний автоплакат "${product.data.title}" з розділу ${categoryName}. Основа ПВХ 3 мм, розмір 500×800 мм, прямий УФ-друк.`,
  "image": productImageUrl,
  "url": productUrl,
  "category": categoryName,
  "offers": {
    "@type": "Offer",
    "price": price,
    "priceCurrency": "UAH",
    "availability": "https://schema.org/InStock",
    "url": productUrl
  }
};
---

<Layout title={`${product.data.title} — Плакат для автошкіл`} description={`Плакат "${product.data.title}" з розділу ${categoryName}. Основа ПВХ 3 мм, розміри 500×800 мм.`}>
  <div class="bg-[#f5f7fa] py-6 sm:py-10 flex-grow">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

      <!-- Breadcrumbs -->
      <nav class="text-xs text-gray-500 mb-6 font-medium flex flex-wrap gap-1 items-center">
        <a href="/" class="text-[#0D47A1] hover:underline">Каталог</a>
        <span>›</span>
        <a href={`/category/${product.data.category}`} class="text-[#0D47A1] hover:underline">{categoryName}</a>
        <span>›</span>
        <span class="text-gray-700 truncate max-w-[240px]">{product.data.title}</span>
      </nav>

      <!-- Main Content Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 lg:gap-10 items-start mb-12">

        <!-- Left: Image -->
        <div
          class="bg-white border border-gray-200 rounded-xl p-6 flex items-center justify-center shadow-sm cursor-zoom-in min-h-[320px]"
          id="image-zoom-trigger"
          title="Натисніть для збільшення"
        >
          <img
            src={`/images/products/${product.data.image}`}
            alt={product.data.title}
            class="max-w-full max-h-[460px] object-contain"
            id="product-thumbnail"
          />
        </div>

        <!-- Right: Details -->
        <div class="flex flex-col gap-5">
          <div>
            <span class="text-xs font-bold uppercase text-[#0D47A1] tracking-wider block mb-1.5">{categoryName}</span>
            <h1 class="text-xl sm:text-2xl font-extrabold text-gray-900 leading-tight">{product.data.title}</h1>
          </div>

          <!-- Price -->
          <div class="flex items-baseline gap-2">
            <span class="text-3xl font-extrabold text-[#E53935]">{price} грн</span>
            <span class="text-sm text-gray-500">з ПДВ</span>
          </div>

          <!-- Specs -->
          <ul class="flex flex-col gap-1.5 text-sm text-gray-700">
            <li class="flex items-center gap-2">
              <span class="text-green-500 font-bold text-base">✔</span>
              <span>Основа ПВХ <strong>3 мм</strong></span>
            </li>
            <li class="flex items-center gap-2">
              <span class="text-green-500 font-bold text-base">✔</span>
              <span>Розмір <strong>500×800 мм</strong></span>
            </li>
            <li class="flex items-center gap-2">
              <span class="text-green-500 font-bold text-base">✔</span>
              <span>Прямий <strong>УФ-друк</strong></span>
            </li>
            <li class="flex items-center gap-2">
              <span class="text-green-500 font-bold text-base">✔</span>
              <span>Доставка <strong>Новою поштою</strong></span>
            </li>
          </ul>

          <!-- Add to Cart -->
          <button
            class="add-to-cart-page-btn w-full py-3.5 text-base font-bold text-white bg-[#0D47A1] rounded-xl hover:bg-[#1565C0] transition-colors cursor-pointer flex items-center justify-center gap-2 shadow-sm"
            data-sku={product.data.sku}
            data-title={product.data.title}
            data-price={price}
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/>
              <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
            </svg>
            Замовити
          </button>
          <p class="text-xs text-gray-400 text-center leading-relaxed">
            Інший розмір або матеріал — вкажіть у кошику при оформленні
          </p>
        </div>
      </div>

      <!-- Similar Products -->
      {similarProducts.length > 0 && (
        <section class="border-t border-gray-200 pt-8">
          <h2 class="text-lg font-bold text-gray-800 mb-5">Схожі плакати</h2>
          <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-4">
            {similarProducts.map(p => (
              <ProductCard product={p.data} />
            ))}
          </div>
        </section>
      )}
    </div>
  </div>

  <!-- Quick Zoom Modal -->
  <div id="quick-zoom-modal" class="fixed inset-0 bg-black/85 z-[2000] flex flex-col items-center justify-center p-4 transition-opacity duration-300 opacity-0 pointer-events-none">
    <div class="relative max-w-5xl w-full h-full flex flex-col items-center justify-center gap-4">
      <img src={`/images/products/${product.data.image}`} alt={product.data.title} class="max-w-full max-h-[85vh] object-contain rounded shadow-2xl bg-white p-2" />
      <button id="close-zoom-btn" class="bg-white text-gray-800 font-bold px-6 py-2.5 rounded-lg shadow-lg hover:bg-gray-100 transition-colors cursor-pointer text-sm">
        Закрити
      </button>
    </div>
  </div>
  <CartDrawer />

  <!-- Schema.org Product + Offer JSON-LD -->
  <script type="application/ld+json" set:html={JSON.stringify(productSchema)} />
</Layout>

<script>
  // Add to Cart Logic
  const btn = document.querySelector('.add-to-cart-page-btn');
  const toast = document.getElementById('cart-toast');
  
  if (btn) {
    btn.addEventListener('click', (e) => {
      e.preventDefault();
      const sku = btn.getAttribute('data-sku');
      const title = btn.getAttribute('data-title');
      const price = Number(btn.getAttribute('data-price'));
      
      if (!sku || !title) return;
      
      try {
        let cart = JSON.parse(localStorage.getItem('shoppingCart') || '[]');
        const existing = cart.find((item: any) => item.sku === sku && !item.isCustom);
        
        if (existing) {
          existing.count++;
        } else {
          cart.push({
            sku,
            title,
            price,
            count: 1,
            isCustom: false,
            customRequirements: null
          });
        }
        
        localStorage.setItem('shoppingCart', JSON.stringify(cart));
        window.dispatchEvent(new Event('cart-updated'));
        
        // Show success toast per philosophy
        if (toast) {
          toast.classList.remove('translate-y-20', 'opacity-0', 'pointer-events-none');
          toast.classList.add('translate-y-0', 'opacity-100');
          setTimeout(() => {
            toast.classList.remove('translate-y-0', 'opacity-100');
            toast.classList.add('translate-y-20', 'opacity-0', 'pointer-events-none');
          }, 2500);
        }
        
      } catch (err) {
        console.error(err);
      }
    });
  }

  // Quick Zoom Modal Logic
  const trigger = document.getElementById('image-zoom-trigger');
  const modal = document.getElementById('quick-zoom-modal');
  const closeBtn = document.getElementById('close-zoom-btn');

  if (trigger && modal && closeBtn) {
    const openZoom = () => {
      modal.classList.remove('opacity-0', 'pointer-events-none');
      modal.classList.add('opacity-100');
      document.body.style.overflow = 'hidden'; // Lock background scroll
    };

    const closeZoom = () => {
      modal.classList.remove('opacity-100');
      modal.classList.add('opacity-0', 'pointer-events-none');
      document.body.style.overflow = ''; // Restore background scroll
    };

    trigger.addEventListener('click', openZoom);
    closeBtn.addEventListener('click', closeZoom);
    modal.addEventListener('click', (e) => {
      if (e.target === modal) closeZoom();
    });

    // Escape Key logic
    window.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !modal.classList.contains('opacity-0')) {
        closeZoom();
      }
    });
  }
</script>
