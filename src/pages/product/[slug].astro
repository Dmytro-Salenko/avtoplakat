---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import ProductSpecs from '../../components/ProductSpecs.astro';
import ProductCard from '../../components/ProductCard.astro';
import CartDrawer from '../../components/CartDrawer.astro';
import { productDefaults } from '../../config/defaults';

export async function getStaticPaths() {
  const allProducts = await getCollection('products');
  const publishedProducts = allProducts.filter(p => p.data.status === 'published');
  
  return publishedProducts.map(product => ({
    params: { slug: product.data.slug },
    props: { product }
  }));
}

const { product } = Astro.props;

const categoryNames: Record<string, string> = {
  'tractor-structure': 'Будова трактора',
  'truck-structure': 'Будова вантажного автомобіля',
  'car-structure': 'Будова легкового автомобіля',
  'road-safety-rules': 'Безпека дорожнього руху',
  'first-aid': 'Домедична допомога'
};

const categoryName = categoryNames[product.data.category] || 'Каталог';

const price = product.data.priceOverride || productDefaults.price;

// Find similar products in the same category
const allProducts = await getCollection('products');
const publishedProducts = allProducts.filter(p => p.data.status === 'published');
const similarProducts = publishedProducts
  .filter(p => p.data.category === product.data.category && p.data.slug !== product.data.slug)
  .slice(0, 4);
---

<Layout title={`${product.data.title} — Плакат для автошкіл`} description={`Плакат "${product.data.title}" з розділу ${categoryName}. Високоякісна основа ПВХ 3мм, розміри 500x800 мм.`}>
  <div class="bg-bg-light py-8 sm:py-12 flex-grow">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      
      <!-- Breadcrumbs -->
      <nav class="text-xs sm:text-sm text-text-muted mb-6 sm:mb-8 font-medium">
        <a href="/" class="text-primary hover:underline">Каталог</a> &raquo;
        <a href={`/category/${product.data.category}`} class="text-primary hover:underline">{categoryName}</a> &raquo;
        <span class="text-text-dark">{product.data.title}</span>
      </nav>
      
      <!-- Main Content Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 lg:gap-12 items-start mb-16">
        
        <!-- Left: Image with Quick Zoom Trigger -->
        <div class="bg-white border border-border rounded-2xl p-6 sm:p-8 flex justify-center shadow-sm cursor-zoom-in" id="image-zoom-trigger" title="Натисніть для збільшення зображення">
          <img src={`/images/products/${product.data.image}`} alt={product.data.title} class="max-w-full h-auto max-h-[500px] object-contain rounded shadow-md" id="product-thumbnail" />
        </div>
        
        <!-- Right: Details -->
        <div class="flex flex-col gap-6">
          <div>
            <span class="text-xs font-bold uppercase text-primary tracking-wider block mb-2">{categoryName}</span>
            <h1 class="text-2xl sm:text-3xl font-extrabold text-text-dark leading-tight">{product.data.title}</h1>
          </div>
          
          <div class="flex items-baseline gap-2">
            <span class="text-3xl font-extrabold text-text-dark">{price} грн</span>
            <span class="text-sm font-semibold text-text-muted">з ПДВ</span>
          </div>
          
          <!-- Buy Actions -->
          <div class="flex flex-col gap-3">
            <button class="btn btn-primary w-full py-4 text-base font-bold add-to-cart-page-btn flex items-center justify-center gap-2 cursor-pointer shadow-sm" data-sku={product.data.sku} data-title={product.data.title} data-price={price}>
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="feather feather-shopping-cart"><circle cx="9" cy="21" r="1"></circle><circle cx="20" cy="21" r="1"></circle><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path></svg>
              Додати у кошик
            </button>
            <p class="text-xs text-text-muted italic leading-relaxed">
              Потрібен інший матеріал чи індивідуальний розмір? Ви зможете вказати це у кошику при оформленні замовлення.
            </p>
          </div>
          
          <!-- Specifications Component -->
          <ProductSpecs product={product.data} />
        </div>
      </div>

      <!-- Similar Products Block -->
      {similarProducts.length > 0 && (
        <section class="border-t border-border pt-12">
          <h2 class="text-xl sm:text-2xl font-bold text-text-dark mb-6">Схожі плакати</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-6">
            {similarProducts.map(p => (
              <ProductCard product={p.data} />
            ))}
          </div>
        </section>
      )}
    </div>
  </div>

  <!-- Quick Zoom Modal -->
  <div id="quick-zoom-modal" class="fixed inset-0 bg-black/85 z-[2000] flex flex-col items-center justify-center p-4 transition-opacity duration-300 opacity-0 pointer-events-none">
    <div class="relative max-w-5xl w-full h-full flex flex-col items-center justify-center gap-4">
      <img src={`/images/products/${product.data.image}`} alt={product.data.title} class="max-w-full max-h-[85vh] object-contain rounded shadow-2xl bg-white p-2" />
      <button id="close-zoom-btn" class="bg-white text-text-dark font-bold px-6 py-2.5 rounded-lg shadow-lg hover:bg-gray-100 transition-colors cursor-pointer text-sm">
        Закрити
      </button>
    </div>
  </div>
  <CartDrawer />
</Layout>

<script>
  // Add to Cart Logic
  const btn = document.querySelector('.add-to-cart-page-btn');
  const toast = document.getElementById('cart-toast');
  
  if (btn) {
    btn.addEventListener('click', (e) => {
      e.preventDefault();
      const sku = btn.getAttribute('data-sku');
      const title = btn.getAttribute('data-title');
      const price = Number(btn.getAttribute('data-price'));
      
      if (!sku || !title) return;
      
      try {
        let cart = JSON.parse(localStorage.getItem('shoppingCart') || '[]');
        const existing = cart.find((item: any) => item.sku === sku && !item.isCustom);
        
        if (existing) {
          existing.count++;
        } else {
          cart.push({
            sku,
            title,
            price,
            count: 1,
            isCustom: false,
            customRequirements: null
          });
        }
        
        localStorage.setItem('shoppingCart', JSON.stringify(cart));
        window.dispatchEvent(new Event('cart-updated'));
        
        // Show success toast per philosophy
        if (toast) {
          toast.classList.remove('translate-y-20', 'opacity-0', 'pointer-events-none');
          toast.classList.add('translate-y-0', 'opacity-100');
          setTimeout(() => {
            toast.classList.remove('translate-y-0', 'opacity-100');
            toast.classList.add('translate-y-20', 'opacity-0', 'pointer-events-none');
          }, 2500);
        }
        
      } catch (err) {
        console.error(err);
      }
    });
  }

  // Quick Zoom Modal Logic
  const trigger = document.getElementById('image-zoom-trigger');
  const modal = document.getElementById('quick-zoom-modal');
  const closeBtn = document.getElementById('close-zoom-btn');

  if (trigger && modal && closeBtn) {
    const openZoom = () => {
      modal.classList.remove('opacity-0', 'pointer-events-none');
      modal.classList.add('opacity-100');
      document.body.style.overflow = 'hidden'; // Lock background scroll
    };

    const closeZoom = () => {
      modal.classList.remove('opacity-100');
      modal.classList.add('opacity-0', 'pointer-events-none');
      document.body.style.overflow = ''; // Restore background scroll
    };

    trigger.addEventListener('click', openZoom);
    closeBtn.addEventListener('click', closeZoom);
    modal.addEventListener('click', (e) => {
      if (e.target === modal) closeZoom();
    });

    // Escape Key logic
    window.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !modal.classList.contains('opacity-0')) {
        closeZoom();
      }
    });
  }
</script>
