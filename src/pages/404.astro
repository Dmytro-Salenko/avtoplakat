---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Помилка 404 — Сторінка не знайдена" description="На жаль, запитувана сторінка не знайдена на сайті AVTOPLAKAT.">
  <section class="bg-bg-light flex-grow flex items-center justify-center py-16 text-center">
    <div class="max-w-md mx-auto px-4 sm:px-6">
      <div class="text-7xl sm:text-8xl font-extrabold text-primary mb-4 leading-none tracking-tight">404</div>
      <h1 class="text-2xl font-bold text-text-dark mb-3">Сторінку не знайдено</h1>
      <p class="text-sm text-text-muted mb-8 leading-relaxed">На жаль, запитувана вами сторінка не існує або була перенесена.</p>
      <a href="/" class="btn btn-primary px-8 py-3.5 font-bold shadow-sm">Повернутися на головну</a>
    </div>
  </section>
</Layout>
