---
import Layout from '../layouts/Layout.astro';
import { siteConfig } from '../config/defaults';
---
<Layout title="Контакти — AVTOPLAKAT UA" description="Зв'яжіться з нами для консультації чи замовлення плакатів за вашими розмірами.">
  <section class="bg-white py-12 flex-grow">
    <div class="max-w-4xl mx-auto px-4 sm:px-6">
      <h1 class="text-2xl sm:text-3xl font-extrabold text-primary mb-8">Наші контакти</h1>
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
        <div class="space-y-6">
          <div class="bg-bg-light border border-border rounded-xl p-6">
            <h3 class="text-sm font-bold uppercase text-primary tracking-wider mb-2">📍 Виробництво та офіс</h3>
            <p class="text-base text-text-dark font-semibold">вул. Шевченка, буд. 100, м. Київ, Україна, 01001</p>
          </div>
          
          {siteConfig.phone && (
            <div class="bg-bg-light border border-border rounded-xl p-6">
              <h3 class="text-sm font-bold uppercase text-primary tracking-wider mb-2">📞 Телефони для замовлень</h3>
              <p class="text-xl sm:text-2xl font-black text-text-dark space-y-2 mt-1">
                <a href={`tel:${siteConfig.phone}`} class="block hover:text-primary hover:underline transition-colors">{siteConfig.phone}</a>
              </p>
              <span class="block text-xs text-text-muted italic mt-3">Пн–Пт: з 9:00 до 18:00, Сб–Нд: вихідні</span>
            </div>
          )}
          
          <div class="bg-bg-light border border-border rounded-xl p-6">
            <h3 class="text-sm font-bold uppercase text-primary tracking-wider mb-2">✉️ Електронна пошта</h3>
            <p class="text-lg sm:text-xl font-bold text-text-dark">
              <a href={`mailto:${siteConfig.email}`} class="hover:text-primary hover:underline transition-colors">{siteConfig.email}</a>
            </p>
          </div>
        </div>
        
        <div class="flex flex-col justify-center space-y-4">
          <h3 class="text-lg font-bold text-text-dark">Зворотний зв'язок</h3>
          <p class="text-sm text-text-muted leading-relaxed">
            Ви можете замовити будь-які плакати з нашого каталогу онлайн або зв'язатися з нашими менеджерами за вказаними номерами телефонів.
          </p>
          <p class="text-sm text-text-muted leading-relaxed">
            Якщо у вас є готові макети або креслення для індивідуального виготовлення стендів, надсилайте їх нам на електронну пошту support@avtoplakat.com.ua для прорахунку вартості.
          </p>
        </div>
      </div>
    </div>
  </section>
</Layout>
