---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import ProductCard from '../components/ProductCard.astro';
import CartDrawer from '../components/CartDrawer.astro';

const allProducts = await getCollection('products');
const publishedProducts = allProducts.filter(p => p.data.status === 'published');

const categories = [
  { slug: 'car-structure',    name: 'Будова автомобіля',  icon: '🚗' },
  { slug: 'truck-structure',  name: 'Будова вантажного',  icon: '🚛' },
  { slug: 'tractor-structure',name: 'Будова трактора',    icon: '🚜' },
  { slug: 'road-safety-rules',name: 'ПДР та безпека',     icon: '🛑' },
  { slug: 'first-aid',        name: 'Домедична допомога', icon: '🩺' },
];
---

<Layout
  title="AVTOPLAKAT UA — Каталог навчальних плакатів для автошкіл"
  description="Навчальні автоплакати для автошкіл України. ПВХ 3 мм, розмір 500×800 мм, швидка доставка Новою поштою."
>
  <!-- Page header + category filter -->
  <section class="bg-white border-b border-gray-200 py-5 sm:py-6">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-xl sm:text-2xl font-extrabold text-gray-900 mb-4">
        Каталог навчальних плакатів
      </h1>

      <!-- Category pills -->
      <div class="flex flex-wrap gap-2">
        {categories.map(cat => (
          <a href={`/category/${cat.slug}`} class="cat-btn">
            <span>{cat.icon}</span>
            {cat.name}
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Product grid -->
  <section class="py-8 sm:py-10 flex-grow" id="catalog">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

      <!-- Count bar -->
      <div class="flex items-center justify-between mb-5">
        <p class="text-sm text-gray-500">
          Всього <span class="font-bold text-gray-800">{publishedProducts.length}</span> плакатів
        </p>
      </div>

      <!-- Grid -->
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-4">
        {publishedProducts.map(product => (
          <ProductCard product={product.data} />
        ))}
      </div>

      <!-- B2B note -->
      <div class="mt-10 bg-[#0D47A1] text-white rounded-xl px-6 py-5 flex flex-col sm:flex-row sm:items-center justify-between gap-4">
        <div>
          <p class="font-bold text-base">Працюємо з ПДВ та державними установами</p>
          <p class="text-sm text-blue-200 mt-0.5">Повний пакет документів для юридичних осіб і ФОП</p>
        </div>
        <a href="/shipping-payment" class="text-sm font-bold text-white underline underline-offset-2 hover:text-yellow-300 whitespace-nowrap">
          Детальніше →
        </a>
      </div>
    </div>
  </section>

  <CartDrawer />
</Layout>
