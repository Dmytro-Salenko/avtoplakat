---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const { 
  title = "AVTOPLAKAT UA — Навчальні автоплакати для автошкіл", 
  description = "Каталог сучасних автоплакатів для автошкіл України. Виготовлення з ПВХ пластику, стандартні та індивідуальні розміри." 
} = Astro.props;
---
<!doctype html>
<html lang="uk" class="h-full">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    
    <!-- SEO Meta Tags -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
  </head>
  <body class="h-full bg-bg-light text-text-dark antialiased">
    <div class="flex flex-col min-h-screen">
      <Header />
      <main class="flex-grow flex flex-col">
        <slot />
      </main>
      <Footer />
    </div>

    <!-- Global Toast Notification per UX audit -->
    <div id="cart-toast" class="fixed bottom-6 right-6 bg-success text-white px-5 py-3 rounded-lg shadow-lg font-bold text-sm z-[3000] transition-all duration-300 transform translate-y-20 opacity-0 pointer-events-none">
      Плакат додано до кошика
    </div>
  </body>
</html>
